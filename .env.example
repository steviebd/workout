# This file documents all environment variables needed for the project.
# DO NOT COMMIT ACTUAL VALUES - use Infisical for secrets management.
# This file is for reference only.

# Cloudflare Configuration
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_API_TOKEN=your_api_token
CLOUDFLARE_D1_DATABASE_ID=your_d1_database_id

# WorkOS Configuration
WORKOS_API_KEY=sk_test_xxx
WORKOS_CLIENT_ID=client_xxx

# Posthog Configuration
POSTHOG_API_KEY=phc_xxx
POSTHOG_PROJECT_URL=https://us.i.posthog.com

# Application Configuration
ENVIRONMENT=development

# Session Configuration
# Generate with: openssl rand -base64 32
SESSION_JWT_SECRET=your_32_byte_base64_encoded_secret_here

# GitHub Actions (for CI/CD)
INFISICAL_CLIENT_ID=your_infisical_client_id
INFISICAL_CLIENT_SECRET=your_infisical_client_secret

# AI Nutrition (Cloudflare AI Gateway with ai-gateway-provider)
# Runtime token used in the `cf-aig-authorization` header for authenticated gateways
CF_AI_GATEWAY_TOKEN=your_ai_gateway_run_token
# Gateway ID from Cloudflare AI Gateway. This does not need to match the Worker name.
AI_GATEWAY_NAME=workout-ai-dev
# Model name for Cloudflare's OpenAI-compatible `/compat/chat/completions` endpoint:
#   Workers AI: workers-ai/@cf/meta/llama-3.3-70b-instruct-fp8-fast
#   xAI: grok/grok-4
#   OpenAI: openai/gpt-4o
#   Google: google/gemini-2.5-pro
AI_MODEL_NAME=workers-ai/@cf/meta/llama-3.3-70b-instruct-fp8-fast

# Playwright and WorkOS test credentials
TEST_USERNAME=example@email.com
TEST_PASSWORD=test123

# Whoop Integration
# Get these from your Whoop Developer Dashboard: https://developer.whoop.com
WHOOP_CLIENT_ID=your_whoop_client_id
WHOOP_CLIENT_SECRET=your_whoop_client_secret
WHOOP_API_URL=https://api.prod.whoop.com
# Generate with: openssl rand -base64 32
WHOOP_TOKEN_ENCRYPTION_KEY=your_32_byte_base64_encoded_key
